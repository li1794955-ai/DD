      "path": "pages/_document.js",
      "content": "import { Html, Head, Main, NextScript } from 'next/document';\n\nexport default function Document() {\n  return (\n    <Html lang=\"zh-CN\">\n      <Head>\n        <meta charSet=\"utf-8\" />\n        <meta name=\"description\" content=\"李栋 - 视觉传达设计师作品集 | Li Dong - Visual Communication Design Portfolio\" />\n        <meta name=\"keywords\" content=\"视觉传达设计,平面设计,设计师作品集\" />\n        <link href=\"https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap\" rel=\"stylesheet\" />\n      </Head>\n      <body className=\"bg-dark-bg text-white\">\n        <Main />\n        <NextScript />\n      </body>\n    </Html>\n  );\n}\n"
    },
    {
      "path": "pages/index.js",
      "content": "import { useEffect } from 'react';\nimport Header from '../components/Header';\nimport Hero from '../components/Hero';\nimport About from '../components/About';\nimport Works from '../components/Works';\nimport Contact from '../components/Contact';\nimport Footer from '../components/Footer';\nimport ScrollProgress from '../components/ScrollProgress';\n\nexport default function Home() {\n  useEffect(() => {\n    const handleScroll = () => {\n      document.documentElement.style.setProperty('--scroll', window.scrollY);\n    };\n    \n    window.addEventListener('scroll', handleScroll);\n    return () => window.removeEventListener('scroll', handleScroll);\n  }, []);\n\n  return (\n    <div className=\"w-full min-h-screen bg-dark-bg\">\n      <ScrollProgress />\n      <Header />\n      <main>\n        <Hero />\n        <About />\n        <Works />\n        <Contact />\n      </main>\n      <Footer />\n    </div>\n  );\n}\n"
    },
    {
      "path": "components/Header.js",
      "content": "import { useState, useEffect } from 'react';\n\nexport default function Header() {\n  const [isScrolled, setIsScrolled] = useState(false);\n  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      setIsScrolled(window.scrollY > 50);\n    };\n    \n    window.addEventListener('scroll', handleScroll);\n    return () => window.removeEventListener('scroll', handleScroll);\n  }, []);\n\n  const scrollToSection = (id) => {\n    const element = document.getElementById(id);\n    if (element) {\n      element.scrollIntoView({ behavior: 'smooth' });\n      setIsMobileMenuOpen(false);\n    }\n  };\n\n  const navItems = [\n    { label: '首页', enLabel: 'Home', id: 'hero' },\n    { label: '关于', enLabel: 'About', id: 'about' },\n    { label: '作品', enLabel: 'Works', id: 'works' },\n    { label: '联系', enLabel: 'Contact', id: 'contact' },\n  ];\n\n  return (\n    <header className={`fixed w-full top-0 z-50 transition-all duration-300 ${\n      isScrolled ? 'bg-dark-bg/95 backdrop-blur-md border-b border-accent-pink/20' : 'bg-transparent'\n    }`}>\n      <div className=\"max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4 flex justify-between items-center\">\n        {/* Logo */}\n        <div className=\"text-2xl font-bold cursor-pointer\" onClick={() => scrollToSection('hero')}>\n          <span className=\"text-white\">Li</span>\n          <span className=\"text-accent-yellow\">D</span>\n        </div>\n\n        {/* Desktop Menu */}\n        <nav className=\"hidden md:flex gap-8\">\n          {navItems.map((item) => (\n            <button\n              key={item.id}\n              onClick={() => scrollToSection(item.id)}\n              className=\"text-sm group relative overflow-hidden\"\n            >\n              <span className=\"text-white group-hover:text-accent-pink transition-colors\">\n                {item.label}\n              </span>\n              <span className=\"text-xs text-gray-400 ml-1 group-hover:text-accent-pink transition-colors\">\n                {item.enLabel}\n              </span>\n              <div className=\"absolute bottom-0 left-0 w-0 h-0.5 bg-gradient-to-r from-accent-yellow to-accent-pink group-hover:w-full transition-all duration-300\"></div>\n            </button>\n          ))}\n        </nav>\n\n        {/* Mobile Menu Button */}\n        <button\n          className=\"md:hidden flex flex-col gap-1.5 cursor-pointer\"\n          onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}\n        >\n          <div className={`w-6 h-0.5 bg-accent-yellow transition-all ${\n            isMobileMenuOpen ? 'rotate-45 translate-y-2' : ''\n          }`}></div>\n          <div className={`w-6 h-0.5 bg-accent-pink transition-all ${\n            isMobileMenuOpen ? 'opacity-0' : ''\n          }`}></div>\n          <div className={`w-6 h-0.5 bg-accent-green transition-all ${\n            isMobileMenuOpen ? '-rotate-45 -translate-y-2' : ''\n          }`}></div>\n        </button>\n      </div>\n\n      {/* Mobile Menu */}\n      {isMobileMenuOpen && (\n        <nav className=\"md:hidden bg-dark-light/95 backdrop-blur-md border-b border-accent-pink/20 px-4 py-4 flex flex-col gap-4\">\n          {navItems.map((item) => (\n            <button\n              key={item.id}\n              onClick={() => scrollToSection(item.id)}\n              className=\"text-left hover:text-accent-yellow transition-colors\"\n            >\n              <span className=\"text-white\">{item.label}</span>\n              <span className=\"text-xs text-gray-400 ml-2\">{item.enLabel}</span>\n            </button>\n          ))}\n        </nav>\n      )}\n    </header>\n  );\n}\n"
    },
    {
      "path": "components/Hero.js",
      "content": "import { useEffect, useRef, useState } from 'react';\n\nexport default function Hero() {\n  const titleRef = useRef(null);\n  const subtitleRef = useRef(null);\n  const [mousePos, setMousePos] = useState({ x: 0, y: 0 });\n\n  useEffect(() => {\n    if (titleRef.current) {\n      titleRef.current.style.animation = 'fadeInUp 1s ease-out';\n    }\n    if (subtitleRef.current) {\n      subtitleRef.current.style.animation = 'fadeInUp 1s ease-out 0.2s both';\n    }\n  }, []);\n\n  useEffect(() => {\n    const handleMouseMove = (e) => {\n      setMousePos({ x: e.clientX, y: e.clientY });\n    };\n\n    window.addEventListener('mousemove', handleMouseMove);\n    return () => window.removeEventListener('mousemove', handleMouseMove);\n  }, []);\n\n  const scrollToWorks = () => {\n    const element = document.getElementById('works');\n    if (element) {\n      element.scrollIntoView({ behavior: 'smooth' });\n    }\n  };\n\n  return (\n    <section\n      id=\"hero\"\n      className=\"relative w-full min-h-screen flex items-center justify-center overflow-hidden pt-20\"\n    >\n      {/* 背景渐变 */}\n      <div className=\"absolute inset-0 bg-gradient-to-br from-dark-bg via-dark-light to-dark-bg\"></div>\n\n      {/* 鼠标跟随光点 */}\n      <div\n        className=\"pointer-events-none fixed w-32 h-32 rounded-full blur-3xl opacity-20 transition-all duration-100\"\n        style={{\n          left: `${mousePos.x}px`,\n          top: `${mousePos.y}px`,\n          background: 'radial-gradient(circle, #FF1493 0%, transparent 70%)',\n          transform: 'translate(-50%, -50%)',\n        }}\n      ></div>\n\n      {/* 内容 */}\n      <div className=\"relative z-10 max-w-4xl mx-auto px-4 text-center\">\n        <h1\n          ref={titleRef}\n          className=\"text-4xl md:text-6xl lg:text-7xl font-bold mb-4 tracking-tight\"\n        >\n          <span className=\"text-white\">李</span>\n          <span className=\"text-accent-yellow\">栋</span>\n          <br />\n          <span className=\"text-2xl md:text-3xl lg:text-4xl text-gray-300 font-light tracking-widest mt-2 inline-block\">\n            Li Dong\n          </span>\n        </h1>\n\n        <div\n          ref={subtitleRef}\n          className=\"mt-8 space-y-3\"\n        >\n          <p className=\"text-lg md:text-xl text-gray-300\">\n            视觉传达设计师\n            <span className=\"text-sm md:text-base text-gray-400 ml-2\">Visual Communication Designer</span>\n          </p>\n          <p className=\"text-base md:text-lg text-gray-400\">\n            用色彩讲故事 | Telling Stories with Colors\n          </p>\n        </div>\n\n        {/* CTA Button */}\n        <button \n          onClick={scrollToWorks}\n          className=\"mt-12 group relative px-8 py-3 border-2 border-accent-pink text-accent-pink hover:text-white transition-colors duration-300 overflow-hidden\"\n        >\n          <div className=\"absolute inset-0 bg-accent-pink transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left\"></div>\n          <span className=\"relative font-medium\">\n            探索作品\n            <span className=\"text-xs ml-2\">Explore Works</span>\n          </span>\n        </button>\n      </div>\n\n      {/* 滚动提示 */}\n      <div className=\"absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce\">\n        <div className=\"w-6 h-10 border-2 border-accent-yellow rounded-full flex items-center justify-center\">\n          <div className=\"w-1 h-2 bg-accent-yellow rounded-full animate-pulse\"></div>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    },
    {
      "path": "components/About.js",
      "content": "import { useEffect, useRef } from 'react';\n\nexport default function About() {\n  const containerRef = useRef(null);\n  const contentRef = useRef(null);\n\n  useEffect(() => {\n    const observer = new IntersectionObserver(\n      ([entry]) => {\n        if (entry.isIntersecting && contentRef.current) {\n          contentRef.current.style.animation = 'fadeInUp 1s ease-out';\n        }\n      },\n      { threshold: 0.1 }\n    );\n\n    if (containerRef.current) {\n      observer.observe(containerRef.current);\n    }\n\n    return () => observer.disconnect();\n  }, []);\n\n  return (\n    <section id=\"about\" ref={containerRef} className=\"relative w-full py-20 md:py-32 px-4 bg-gradient-to-b from-dark-bg to-dark-light\">\n      <div className=\"max-w-6xl mx-auto\">\n        {/* 分割线 */}\n        <div className=\"flex items-center gap-4 mb-12\">\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-yellow to-accent-pink\"></div>\n          <h2 className=\"text-3xl md:text-4xl font-bold text-white whitespace-nowrap\">\n            关于我\n            <span className=\"text-2xl md:text-3xl text-accent-yellow ml-4\">About</span>\n          </h2>\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-pink to-accent-yellow\"></div>\n        </div>\n\n        <div ref={contentRef} className=\"grid md:grid-cols-3 gap-8 items-start mt-12\">\n          {/* 左侧：个人照片 */}\n          <div className=\"flex justify-center\">\n            <div className=\"relative w-48 h-56 md:w-56 md:h-72 group\">\n              {/* 背景装饰 */}\n              <div className=\"absolute inset-0 bg-gradient-to-br from-accent-yellow to-accent-pink opacity-20 transform group-hover:scale-105 transition-transform duration-300\"></div>\n              \n              {/* 照片 */}\n              <img\n                src=\"https://via.placeholder.com/280x360/1a1f3a/FFD700?text=Personal+Photo\"\n                alt=\"李栋\"\n                className=\"relative w-full h-full object-cover border-2 border-accent-pink\"\n              />\n\n              {/* 悬停效果 */}\n              <div className=\"absolute inset-0 bg-gradient-to-t from-dark-bg to-transparent opacity-0 group-hover:opacity-50 transition-opacity duration-300\"></div>\n            </div>\n          </div>\n\n          {/* 右侧：信息卡片 */}\n          <div className=\"md:col-span-2 space-y-8\">\n            {/* 基本信息 */}\n            <div className=\"border-l-4 border-accent-yellow pl-6\">\n              <h3 className=\"text-lg font-bold text-white mb-4\">基本信息</h3>\n              <div className=\"space-y-3 text-base text-gray-300\">\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">姓名：</span>\n                  李栋 <span className=\"text-xs text-gray-400\">(She/Her)</span>\n                </p>\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">出生日期：</span>\n                  2004.02.04\n                </p>\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">专业：</span>\n                  视觉传达设计 <span className=\"text-xs text-gray-400\">Visual Communication Design</span>\n                </p>\n              </div>\n            </div>\n\n            {/* 个人简介 */}\n            <div className=\"border-l-4 border-accent-green pl-6\">\n              <h3 className=\"text-lg font-bold text-white mb-4\">自我介绍</h3>\n              <p className=\"text-base text-gray-300 leading-relaxed\">\n                我是一名视觉传达设计师，热衷于用颜色和设计讲故事。擅长平面设计、品牌设计、视频制作等多个领域。致力于将创意想法转化为视觉语言，为每一个项目注入灵魂。\n              </p>\n              <p className=\"text-xs text-gray-400 mt-3\">\n                I am a visual communication designer passionate about telling stories through colors and design. Skilled in graphic design, branding, video production and more.\n              </p>\n            </div>\n\n            {/* 联系方式 */}\n            <div className=\"border-l-4 border-accent-cyan pl-6\">\n              <h3 className=\"text-lg font-bold text-white mb-4\">联系方式</h3>\n              <div className=\"space-y-2 text-base text-gray-300\">\n                <p>\n                  <span className=\"text-accent-cyan font-semibold\">📞 电话：</span>\n                  15523957239\n                </p>\n                <p>\n                  <span className=\"text-accent-cyan font-semibold\">💬 QQ：</span>\n                  1303212579\n                </p>\n                <p>\n                  <span className=\"text-accent-cyan font-semibold\">📧 邮箱：</span>\n                  <a href=\"mailto:1303212579@qq.com\" className=\"text-accent-yellow hover:underline\">\n                    1303212579@qq.com\n                  </a>\n                </p>\n              </div>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    },
    {
      "path": "components/Works.js",
      "content": "import { useEffect, useRef, useState } from 'react';\n\nconst categories = [\n  { id: 'graphic', label: '平面设计作品', enLabel: 'Graphic Design', color: 'accent-yellow' },\n  { id: 'case', label: '设计案例分析', enLabel: 'Design Cases', color: 'accent-pink' },\n  { id: 'motion', label: '视频/动态作品', enLabel: 'Motion & Video', color: 'accent-green' },\n];\n\nconst works = [\n  { id: 1, category: 'graphic', title: '品牌设计', desc: '现代简约风格品牌 Logo & VI 设计' },\n  { id: 2, category: 'graphic', title: '海报设计', desc: '创意活动宣传海报系列' },\n  { id: 3, category: 'graphic', title: '书籍装帧', desc: '艺术类书籍封面设计' },\n  { id: 4, category: 'case', title: '餐饮品牌案例', desc: '从调研到视觉落地的完整案例' },\n  { id: 5, category: 'case', title: '服装品牌案例', desc: '品牌重塑项目总结' },\n  { id: 6, category: 'case', title: '文创产品案例', desc: '包装设计与视觉策划' },\n  { id: 7, category: 'motion', title: '品牌宣传视频', desc: '3D 动画与视频剪辑' },\n  { id: 8, category: 'motion', title: '动画演示', desc: '交互动画设计展示' },\n  { id: 9, category: 'motion', title: '视觉效果', desc: 'VFX 特效作品' },\n];\n\nexport default function Works() {\n  const containerRef = useRef(null);\n  const [activeCategory, setActiveCategory] = useState('graphic');\n  const cardsRef = useRef([]);\n\n  const filteredWorks = works.filter(work => work.category === activeCategory);\n\n  useEffect(() => {\n    cardsRef.current.forEach((card, index) => {\n      if (card) {\n        card.style.animation = `fadeInUp 0.8s ease-out ${index * 0.1}s both`;\n      }\n    });\n  }, [activeCategory]);\n\n  return (\n    <section id=\"works\" ref={containerRef} className=\"relative w-full py-20 md:py-32 px-4 bg-dark-bg\">\n      <div className=\"max-w-6xl mx-auto\">\n        {/* 标题 */}\n        <div className=\"flex items-center gap-4 mb-12\">\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-green to-accent-pink\"></div>\n          <h2 className=\"text-3xl md:text-4xl font-bold text-white whitespace-nowrap\">\n            作品展示\n            <span className=\"text-2xl md:text-3xl text-accent-green ml-4\">Works</span>\n          </h2>\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-pink to-accent-green\"></div>\n        </div>\n\n        {/* 分类选项卡 */}\n        <div className=\"flex flex-wrap gap-4 mb-16 justify-center\">\n          {categories.map((cat) => (\n            <button\n              key={cat.id}\n              onClick={() => setActiveCategory(cat.id)}\n              className={`relative px-6 py-3 font-semibold transition-all duration-300 group ${\n                activeCategory === cat.id\n                  ? 'text-white'\n                  : 'text-gray-400 hover:text-gray-300'\n              }`}\n            >\n              <span>\n                {cat.label}\n                <span className={`text-xs ml-2 ${\n                  activeCategory === cat.id ? 'text-accent-yellow' : 'text-gray-500'\n                }`}>\n                  {cat.enLabel}\n                </span>\n              </span>\n              {activeCategory === cat.id && (\n                <div className=\"absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-accent-yellow via-accent-pink to-accent-green\"></div>\n              )}\n            </button>\n          ))}\n        </div>\n\n        {/* 作品网格 */}\n        <div className=\"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6\">\n          {filteredWorks.map((work, index) => (\n            <div\n              key={work.id}\n              ref={(el) => (cardsRef.current[index] = el)}\n              className=\"group relative overflow-hidden bg-dark-light border border-gray-700 hover:border-accent-pink transition-all duration-300 cursor-pointer\"\n            >\n              {/* 背景图片占位符 */}\n              <div className=\"w-full h-48 bg-gradient-to-br from-accent-yellow/10 to-accent-pink/10 flex items-center justify-center group-hover:from-accent-yellow/20 group-hover:to-accent-pink/20 transition-all duration-300\">\n                <img\n                  src={`https://via.placeholder.com/400x300/2a3f5f/${work.category === 'graphic' ? 'FFD700' : work.category === 'case' ? 'FF1493' : '00FF41'}?text=${work.title}`}\n                  alt={work.title}\n                  className=\"w-full h-full object-cover\"\n                />\n              </div>\n\n              {/* 内容 */}\n              <div className=\"p-6\">\n                <h3 className=\"text-lg font-bold text-white mb-2 group-hover:text-accent-yellow transition-colors\">\n                  {work.title}\n                </h3>\n                <p className=\"text-sm text-gray-400 mb-4\">\n                  {work.desc}\n                </p>\n\n                {/* 悬停效果 */}\n                <div className=\"flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity duration-300\">\n                  <span className=\"text-accent-pink text-xs\">查看项目 →</span>\n                </div>\n              </div>\n\n              {/* 边框动画 */}\n              <div className=\"absolute inset-0 border-2 border-transparent group-hover:border-accent-pink transition-colors duration-300 pointer-events-none\"></div>\n            </div>\n          ))}\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    },
    {
      "path": "components/Contact.js",
      "content": "import { useRef, useState } from 'react';\n\nexport default function Contact() {\n  const containerRef = useRef(null);\n  const [formData, setFormData] = useState({\n    name: '',\n    email: '',\n    message: '',\n  });\n  const [submitted, setSubmitted] = useState(false);\n\n  const handleChange = (e) => {\n    const { name, value } = e.target;\n    setFormData((prev) => ({ ...prev, [name]: value }));\n  };\n\n  const handleSubmit = (e) => {\n    e.preventDefault();\n    console.log('Form submitted:', formData);\n    setSubmitted(true);\n    setTimeout(() => {\n      setFormData({ name: '', email: '', message: '' });\n      setSubmitted(false);\n    }, 3000);\n  };\n\n  return (\n    <section id=\"contact\" ref={containerRef} className=\"relative w-full py-20 md:py-32 px-4 bg-gradient-to-b from-dark-light to-dark-bg\">\n      <div className=\"max-w-4xl mx-auto\">\n        {/* 标题 */}\n        <div className=\"flex items-center gap-4 mb-12\">\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-cyan to-accent-yellow\"></div>\n          <h2 className=\"text-3xl md:text-4xl font-bold text-white whitespace-nowrap\">\n            联系我\n            <span className=\"text-2xl md:text-3xl text-accent-cyan ml-4\">Contact</span>\n          </h2>\n          <div className=\"h-0.5 flex-1 bg-gradient-to-r from-accent-yellow to-accent-cyan\"></div>\n        </div>\n\n        <div className=\"grid md:grid-cols-2 gap-12 mt-16\">\n          {/* 联系信息 */}\n          <div className=\"space-y-8\">\n            <div className=\"border-l-4 border-accent-yellow pl-6\">\n              <h3 className=\"text-lg font-bold text-white mb-2\">快速联系</h3>\n              <p className=\"text-xs text-gray-400\">Quick Contact</p>\n              <p className=\"text-base text-gray-300 mt-4\">\n                有任何设计需求或合作机会？欢迎联系我！\n              </p>\n              <p className=\"text-xs text-gray-400 mt-1\">\n                Any design inquiries or collaboration opportunities? Feel free to reach out!\n              </p>\n            </div>\n\n            <div className=\"border-l-4 border-accent-pink pl-6\">\n              <h3 className=\"text-lg font-bold text-white mb-3\">联系方式</h3>\n              <div className=\"space-y-2 text-base text-gray-300\">\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">📞</span>\n                  <a href=\"tel:15523957239\" className=\"ml-2 hover:text-accent-yellow transition-colors\">\n                    15523957239\n                  </a>\n                </p>\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">💬</span>\n                  <span className=\"ml-2\">QQ: 1303212579</span>\n                </p>\n                <p>\n                  <span className=\"text-accent-pink font-semibold\">📧</span>\n                  <a href=\"mailto:1303212579@qq.com\" className=\"ml-2 hover:text-accent-yellow transition-colors\">\n                    1303212579@qq.com\n                  </a>\n                </p>\n              </div>\n            </div>\n          </div>\n\n          {/* 联系表单 */}\n          <form onSubmit={handleSubmit} className=\"space-y-6\">\n            <div>\n              <label className=\"block text-sm font-semibold text-white mb-2\">\n                姓名 <span className=\"text-xs text-gray-400\">Name</span>\n              </label>\n              <input\n                type=\"text\"\n                name=\"name\"\n                value={formData.name}\n                onChange={handleChange}\n                className=\"w-full bg-dark-bg border border-gray-600 text-white px-4 py-2 focus:border-accent-yellow focus:outline-none transition-colors\"\n                placeholder=\"请输入您的名字\"\n              />\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-semibold text-white mb-2\">\n                邮箱 <span className=\"text-xs text-gray-400\">Email</span>\n              </label>\n              <input\n                type=\"email\"\n                name=\"email\"\n                value={formData.email}\n                onChange={handleChange}\n                className=\"w-full bg-dark-bg border border-gray-600 text-white px-4 py-2 focus:border-accent-pink focus:outline-none transition-colors\"\n                placeholder=\"your@email.com\"\n              />\n            </div>\n\n            <div>\n              <label className=\"block text-sm font-semibold text-white mb-2\">\n                留言 <span className=\"text-xs text-gray-400\">Message</span>\n              </label>\n              <textarea\n                name=\"message\"\n                value={formData.message}\n                onChange={handleChange}\n                rows=\"4\"\n                className=\"w-full bg-dark-bg border border-gray-600 text-white px-4 py-2 focus:border-accent-green focus:outline-none transition-colors resize-none\"\n                placeholder=\"请输入您的留言...\"\n              />\n            </div>\n\n            <button\n              type=\"submit\"\n              className=\"w-full group relative px-6 py-3 bg-transparent border-2 border-accent-pink text-accent-pink hover:text-white font-semibold transition-colors duration-300 overflow-hidden\"\n            >\n              <div className=\"absolute inset-0 bg-accent-pink transform scale-x-0 group-hover:scale-x-100 transition-transform duration-300 origin-left -z-10\"></div>\n              <span className=\"\">\n                发送消息\n                <span className=\"text-xs ml-2\">Send Message</span>\n              </span>\n            </button>\n\n            {submitted && (\n              <p className=\"text-center text-accent-green text-sm\">\n                ✓ 感谢您的留言！我会尽快回复。\n              </p>\n            )}\n          </form>\n        </div>\n      </div>\n    </section>\n  );\n}\n"
    },
    {
      "path": "components/Footer.js",
      "content": "export default function Footer() {\n  const currentYear = new Date().getFullYear();\n\n  const scrollToSection = (id) => {\n    const element = document.getElementById(id);\n    if (element) {\n      element.scrollIntoView({ behavior: 'smooth' });\n    }\n  };\n\n  return (\n    <footer className=\"w-full bg-dark-bg border-t border-gray-700 py-8 px-4\">\n      <div className=\"max-w-6xl mx-auto\">\n        <div className=\"grid md:grid-cols-3 gap-8 mb-8\">\n          {/* Logo */}\n          <div>\n            <div className=\"text-2xl font-bold mb-2 cursor-pointer\" onClick={() => scrollToSection('hero')}>\n              <span className=\"text-white\">Li</span>\n              <span className=\"text-accent-yellow\">D</span>\n            </div>\n            <p className=\"text-xs text-gray-400\">\n              Visual Communication Designer\n            </p>\n          </div>\n\n          {/* 快速导航 */}\n          <div>\n            <h4 className=\"text-base font-semibold text-white mb-4\">\n              快速导航\n              <span className=\"text-xs text-gray-400 ml-2\">Navigation</span>\n            </h4>\n            <ul className=\"space-y-2 text-sm text-gray-400\">\n              <li><button onClick={() => scrollToSection('about')} className=\"hover:text-accent-yellow transition-colors\">关于 About</button></li>\n              <li><button onClick={() => scrollToSection('works')} className=\"hover:text-accent-yellow transition-colors\">作品 Works</button></li>\n              <li><button onClick={() => scrollToSection('contact')} className=\"hover:text-accent-yellow transition-colors\">联系 Contact</button></li>\n            </ul>\n          </div>\n\n          {/* 社交媒体 */}\n          <div>\n            <h4 className=\"text-base font-semibold text-white mb-4\">\n              社交媒体\n              <span className=\"text-xs text-gray-400 ml-2\">Social</span>\n            </h4>\n            <div className=\"flex gap-4\">\n              <a href=\"#\" className=\"w-10 h-10 rounded-full border border-accent-pink text-accent-pink hover:bg-accent-pink hover:text-white flex items-center justify-center transition-all text-xs\">\n                IG\n              </a>\n              <a href=\"#\" className=\"w-10 h-10 rounded-full border border-accent-yellow text-accent-yellow hover:bg-accent-yellow hover:text-dark-bg flex items-center justify-center transition-all text-xs\">\n                WX\n              </a>\n              <a href=\"#\" className=\"w-10 h-10 rounded-full border border-accent-green text-accent-green hover:bg-accent-green hover:text-dark-bg flex items-center justify-center transition-all text-xs\">\n                TW\n              </a>\n            </div>\n          </div>\n        </div>\n\n        {/* 分割线 */}\n        <div className=\"h-0.5 bg-gradient-to-r from-accent-yellow via-accent-pink to-accent-green mb-8\"></div>\n\n        {/* 版权 */}\n        <div className=\"text-center text-xs text-gray-500\">\n          <p>\n            © {currentYear} Li Dong. All rights reserved. | Designed & Built with ♥\n          </p>\n        </div>\n      </div>\n    </footer>\n  );\n}\n"
    },
    {
      "path": "components/ScrollProgress.js",
      "content": "import { useEffect, useState } from 'react';\n\nexport default function ScrollProgress() {\n  const [progress, setProgress] = useState(0);\n\n  useEffect(() => {\n    const handleScroll = () => {\n      const winScroll = document.documentElement.scrollTop;\n      const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;\n      const scrolled = (winScroll / height) * 100;\n      setProgress(scrolled);\n    };\n\n    window.addEventListener('scroll', handleScroll);\n    return () => window.removeEventListener('scroll', handleScroll);\n  }, []);\n\n  return (\n    <div\n      className=\"fixed top-0 left-0 h-1 bg-gradient-to-r from-accent-yellow via-accent-pink to-accent-green z-50 transition-all duration-300\"\n      style={{ width: `${progress}%` }}\n    ></div>\n  );\n}\n"
    },
    {
      "path": "styles/globals.css",
      "content": "@import 'tailwindcss/base';\n@import 'tailwindcss/components';\n@import 'tailwindcss/utilities';\n\n/* 全局样式 */\n* {\n  margin: 0;\n  padding: 0;\n  box-sizing: border-box;\n}\n\nhtml {\n  scroll-behavior: smooth;\n}\n\nbody {\n  background-color: #0a0e27;\n  color: #ffffff;\n  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen',\n    'Ubuntu', 'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue',\n    'Microsoft YaHei', '微软雅黑', 'Noto Sans SC', 'PingFang SC',\n    'Hiragino Sans GB', 'STHeiti', sans-serif;\n  overflow-x: hidden;\n}\n\n/* 滚动条样式 */\n::-webkit-scrollbar {\n  width: 8px;\n}\n\n::-webkit-scrollbar-track {\n  background: #0a0e27;\n}\n\n::-webkit-scrollbar-thumb {\n  background: #FF1493;\n  border-radius: 4px;\n}\n\n::-webkit-scrollbar-thumb:hover {\n  background: #FFD700;\n}\n\n/* 文本选择 */\n::selection {\n  background-color: #FF1493;\n  color: #0a0e27;\n}\n\n/* 链接样式 */\na {\n  text-decoration: none;\n  color: inherit;\n}\n\n/* 按钮重置 */\nbutton {\n  background: none;\n  border: none;\n  cursor: pointer;\n  font-family: inherit;\n}\n\ninput,\ntextarea {\n  font-family: inherit;\n}\n"
    },
    {
      "path": "styles/animations.css",
      "content": "/* 动画定义 */\n\n/* 淡入上升 */\n@keyframes fadeInUp {\n  from {\n    opacity: 0;\n    transform: translateY(30px);\n  }\n  to {\n    opacity: 1;\n    transform: translateY(0);\n  }\n}\n\n/* 淡入 */\n@keyframes fadeIn {\n  from {\n    opacity: 0;\n  }\n  to {\n    opacity: 1;\n  }\n}\n\n/* 滑入左 */\n@keyframes slideInLeft {\n  from {\n    opacity: 0;\n    transform: translateX(-40px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n/* 滑入右 */\n@keyframes slideInRight {\n  from {\n    opacity: 0;\n    transform: translateX(40px);\n  }\n  to {\n    opacity: 1;\n    transform: translateX(0);\n  }\n}\n\n/* 缩放进入 */\n@keyframes scaleIn {\n  from {\n    opacity: 0;\n    transform: scale(0.95);\n  }\n  to {\n    opacity: 1;\n    transform: scale(1);\n  }\n}\n\n/* 脉冲 */\n@keyframes pulse {\n  0%, 100% {\n    opacity: 1;\n  }\n  50% {\n    opacity: 0.5;\n  }\n}\n\n/* 浮动 */\n@keyframes float {\n  0%, 100% {\n    transform: translateY(0px);\n  }\n  50% {\n    transform: translateY(-10px);\n  }\n}\n\n/* 旋转 */\n@keyframes spin {\n  from {\n    transform: rotate(0deg);\n  }\n  to {\n    transform: rotate(360deg);\n  }\n}\n\n/* 下弹 */\n@keyframes bounce {\n  0%, 100% {\n    transform: translateY(0);\n  }\n  50% {\n    transform: translateY(-20px);\n  }\n}\n\n/* 响应式文本大小 */\n@media (max-width: 768px) {\n  h1 {\n    font-size: 2.25rem;\n  }\n\n  h2 {\n    font-size: 1.875rem;\n  }\n\n  h3 {\n    font-size: 1.5rem;\n  }\n}\n"
    },
    {
      "path": ".github/workflows/deploy.yml",
      "content": "name: Deploy to GitHub Pages\n\non:\n  push:\n    branches: [main]\n  pull_request:\n    branches: [main]\n\njobs:\n  deploy:\n    runs-on: ubuntu-latest\n\n    strategy:\n      matrix:\n        node-version: [18.x]\n\n    steps:\n      - uses: actions/checkout@v3\n\n      - name: Use Node.js ${{ matrix.node-version }}\n        uses: actions/setup-node@v3\n        with:\n          node-version: ${{ matrix.node-version }}\n          cache: 'npm'\n\n      - name: Install dependencies\n        run: npm ci\n\n      - name: Build\n        run: npm run build\n\n      - name: Deploy to GitHub Pages\n        uses: peaceiris/actions-gh-pages@v3\n        with:\n          github_token: ${{ secrets.GITHUB_TOKEN }}\n          publish_dir: ./out\n"
    },
    {
      "path": "README.md",
      "content": "# 李栋的作品集网站 | Li Dong's Portfolio Website\n\n一个现代化、极简艺术风格的个人作品集网站。\n\nA modern, minimalist art-style personal portfolio website.\n\n## 🎨 设计特点 | Design Features\n\n- ✨ **撞色艺术风格** - 黄、粉、绿撞色配色方案\n- 🎬 **流畅动画** - 平滑交互效果\n- 📱 **完全响应式** - 支持所有设备尺寸\n- 🌙 **深色主题** - 专业的暗色背景设计\n- 🖱️ **鼠标跟随** - 创意互动效果\n- 📊 **滚动进度条** - 视觉反馈\n\n## 🛠️ 技术栈 | Tech Stack\n\n- **框架**: Next.js 14\n- **样式**: Tailwind CSS\n- **动画**: 原生 CSS Animation\n- **部署**: GitHub Pages / Vercel\n\n## 📋 项目结构 | Project Structure\n\n```\nportfolio/\n├── pages/\n│   ├── _app.js           # App 包装器\n│   ├── _document.js      # HTML 文档结构\n│   └── index.js          # 主页面\n├── components/\n│   ├── Header.js         # 导航栏\n│   ├── Hero.js           # 首屏\n│   ├── About.js          # 关于版块\n│   ├── Works.js          # 作品展示\n│   ├── Contact.js        # 联系方式\n│   ├── Footer.js         # 底部\n│   └── ScrollProgress.js # 滚动进度条\n├── styles/\n│   ├── globals.css       # 全局样式\n│   └── animations.css    # 动画定义\n└── public/               # 静态资源\n```\n\n## 🚀 快速开始 | Quick Start\n\n### 安装依赖 | Install Dependencies\n\n```bash\nnpm install\n```\n\n### 本地开发 | Development\n\n```bash\nnpm run dev\n# 访问 http://localhost:3000\n```\n\n### 生产构建 | Production Build\n\n```bash\nnpm run build\n```\n\n## 📝 自定义内容 | Customize Content\n\n### 修改个人信息\n\n编辑 `components/About.js`：\n```javascript\n// 修改姓名、生日等信息\n<p>姓名：李栋</p>\n<p>出生日期：2004.02.04</p>\n```\n\n### 添加作品\n\n编辑 `components/Works.js` 中的 `works` 数组：\n```javascript\nconst works = [\n  { id: 1, category: 'graphic', title: '项目名称', desc: '项目描述' },\n  // ...\n];\n```\n\n### 修改配色\n\n编辑 `tailwind.config.js`：\n```javascript\ncolors: {\n  'accent-yellow': '#FFD700',\n  'accent-pink': '#FF1493',\n  'accent-green': '#00FF41',\n}\n```\n\n## 📸 更新个人照片 | Update Personal Photo\n\n1. 将照片放在 `public/images/` 目录\n2. 在 `components/About.js` 中修改图片路径\n\n```javascript\n<img\n  src=\"/images/your-photo.jpg\"\n  alt=\"李栋\"\n  className=\"...\"\n/>\n```\n\n## 📱 响应式设计 | Responsive Design\n\n- 📱 Mobile (< 640px)\n- 📱 Tablet (640px - 1024px)\n- 💻 Desktop (> 1024px)\n\n## 🌐 部署 | Deployment\n\n项目已配置自动部署到 GitHub Pages。\n\n访问地址：`https://LI794955.github.io/portfolio/`\n\n## 📧 联系信息 | Contact\n\n- 📞 电话: 15523957239\n- 💬 QQ: 1303212579\n- 📧 邮箱: 1303212579@qq.com\n\n## 📄 许可证 | License\n\nMIT License - 自由使用和修改\n\n---\n\n**最后更新 | Last Updated**: 2024\n\n**快乐设计！| Happy Designing! 🎨**\n"
